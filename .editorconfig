# Top-most EditorConfig file
root = true

# All files
[*]
max_line_length = 200
ktlint_standard_final-newline = disabled

ktlint_function_signature_rule_force_multiline_when_parameter_count_greater_or_equal_than = 4
ktlint_class_signature_rule_force_multiline_when_parameter_count_greater_or_equal_than = 2
[*.{kt,kts}]
ij_kotlin_imports_layout = java.**, javax.**, |, kotlin.**, kotlinx.**, |, *, |, ^, no.nav.**

# Exclude .txt files from formatting
[*.txt]
max_line_length = off
trim_trailing_whitespace = false

[**/generated/**/*]
ktlint = disabled